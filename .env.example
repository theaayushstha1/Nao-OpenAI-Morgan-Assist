# Nao-OpenAI-Morgan-Assist environment
# Copy to `.env` at repo root. `.env` is gitignored.

# ──────────── REQUIRED ────────────

# OpenAI — used by all agents + Whisper + embeddings + vision
OPENAI_API_KEY=sk-...

# ──────────── REQUIRED FOR CHATBOT RAG ────────────
# The chatbot agent queries CS Navigator's Vertex AI Search datastore.
# Without GCP auth, chatbot returns "I'm not sure" for factual questions;
# other agents (chat, skills, therapist) still work fine.
#
# Auth: run `gcloud auth application-default login` once, OR set
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json for prod.

GOOGLE_CLOUD_PROJECT=csnavigator-vertex-ai
VERTEX_LOCATION=us
VERTEX_DATASTORE_ID=csnavigator-kb-v7

# ──────────── OPTIONAL (MODEL OVERRIDES) ────────────
# Default is gpt-4o-mini for most agents, gpt-4o for therapist (for vision).
# Setting THERAPIST_MODEL=gpt-4o-mini cuts cost ~10x with modest quality loss.

# ROUTER_MODEL=gpt-4o-mini
# CHAT_MODEL=gpt-4o-mini
# CHATBOT_MODEL=gpt-4o-mini
# THERAPIST_MODEL=gpt-4o
# SKILLS_MODEL=gpt-4o-mini
# CRISIS_MODEL=gpt-4o-mini
# WHISPER_MODEL=whisper-1

# ──────────── OPTIONAL (NETWORKING) ────────────

# NAO_IP=172.20.95.111
# NAO_PORT=9559
# SERVER_IP=0.0.0.0
# SERVER_PORT=5000

# ──────────── OPTIONAL (PERSISTENCE / TRACING) ────────────

# SESSION_DB=server/nao.db
# OPENAI_AGENTS_TRACE=1

# ──────────── OPTIONAL (SAGE-CBT research layer) ────────────
# Off by default — set SAGE_TOPOLOGY to enable the topology dispatcher.
# Values: passthrough (default, existing router behavior) | supervisor_veto |
# debate | shared_pool.

# SAGE_TOPOLOGY=passthrough

# SafetyAgent provider. Only used when SAGE_TOPOLOGY != "passthrough".
# If set to "claude", ANTHROPIC_API_KEY must also be set.

# SAGE_SAFETY_PROVIDER=openai
# SAFETY_MODEL_OPENAI=gpt-4o
# SAFETY_MODEL_CLAUDE=claude-opus-4-7
# ANTHROPIC_API_KEY=

# SAGE_LOG_DIR=logs
