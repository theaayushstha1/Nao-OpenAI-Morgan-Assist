# ──────────────────────────────────────────────────────────────────
# .env.example — copy to .env, fill in secrets locally. Never commit .env.
#
# This file is the source of truth for environment variables the project
# reads. Phase 1 of the v2 rework (docs/PRD_v2.md, docs/PHASE_1_TASK_MAP.md)
# adds the USE_WS / WS_* / LOG_* / METRICS_* / TTS_CHUNK_* / MIC_GATE_* /
# WS_RECONNECT_* block at the bottom — those drive the FastAPI + WebSocket
# transport. Default of USE_WS=0 keeps the legacy Flask path booting.
# ──────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────────
# API keys — paste your keys here in your local .env (NEVER commit)
# ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=PASTE_OPENAI_KEY_HERE
DEEPGRAM_API_KEY=PASTE_DEEPGRAM_KEY_HERE
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────────────────────────
# NAO robot connection
# ──────────────────────────────────────────────────────────────────
NAO_IP=172.20.95.127
NAO_PORT=9559
NAO_PASSWORD=PASTE_NAO_PASSWORD_HERE

# ──────────────────────────────────────────────────────────────────
# Local server (Flask today, FastAPI/WS when USE_WS=1) — where NAO calls in
# ──────────────────────────────────────────────────────────────────
SERVER_IP=0.0.0.0
SERVER_PORT=5050
NAO_SHARED_SECRET=PASTE_SHARED_SECRET_HERE

# ──────────────────────────────────────────────────────────────────
# OpenAI TTS (replaces ElevenLabs voice clone)
# Voices: nova (warm female), shimmer (soft female), coral, sage
# ──────────────────────────────────────────────────────────────────
USE_OPENAI_TTS=1
OPENAI_TTS_VOICE=nova
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_GAIN_DB=16

# ──────────────────────────────────────────────────────────────────
# Per-agent OpenAI models
# ──────────────────────────────────────────────────────────────────
ROUTER_MODEL=gpt-4.1-nano
CHAT_MODEL=gpt-4.1-nano
CHATBOT_MODEL=gpt-4.1-mini
THERAPIST_MODEL=gpt-4.1-mini
SKILLS_MODEL=gpt-4.1-nano
CRISIS_MODEL=gpt-4.1
CBT_MODEL=gpt-4.1-mini
GROUNDING_MODEL=gpt-4.1-mini
NANO_MAX_TOKENS=200
MINI_MAX_TOKENS=400

# ──────────────────────────────────────────────────────────────────
# ASR (Deepgram Nova-2 with Whisper fallback)
# ──────────────────────────────────────────────────────────────────
USE_DEEPGRAM=1
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en-US
WHISPER_MODEL=gpt-4o-mini-transcribe

# ──────────────────────────────────────────────────────────────────
# Semantic endpointing (decide whether user finished their thought)
# ──────────────────────────────────────────────────────────────────
USE_SEMANTIC_ENDPOINT=0
SEMANTIC_ENDPOINT_MODEL=gpt-4.1-nano

# ──────────────────────────────────────────────────────────────────
# Vertex AI Search (Morgan State CS knowledge base)
# ──────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=csnavigator-vertex-ai
VERTEX_LOCATION=us
VERTEX_DATASTORE_ID=csnavigator-kb-v7

# ──────────────────────────────────────────────────────────────────
# SAGE-CBT topology (passthrough = default)
# ──────────────────────────────────────────────────────────────────
SAGE_TOPOLOGY=passthrough
SAGE_SAFETY_PROVIDER=openai
SAFETY_MODEL_OPENAI=gpt-4o
SAFETY_MODEL_CLAUDE=claude-opus-4-7
SAGE_LOG_DIR=logs

# ──────────────────────────────────────────────────────────────────
# Session DB & tracing
# ──────────────────────────────────────────────────────────────────
SESSION_DB=server/nao.db
OPENAI_AGENTS_TRACE=1

# ──────────────────────────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────────────────────────
PROACTIVE_GREET_ENABLED=0
IMAGE_PER_TURN=1

# ──────────────────────────────────────────────────────────────────
# Phase 1 (PRD v2) — FastAPI + WebSocket transport
# Flip USE_WS=1 to run uvicorn server.app_ws instead of Flask. The old
# Flask path stays as the default during the deployment week.
# ──────────────────────────────────────────────────────────────────

# Feature flag. 1 = boot uvicorn (FastAPI/WS), 0 = boot Flask (legacy).
USE_WS=0
# uvicorn bind. WS_PORT defaults to SERVER_PORT if you leave it blank.
WS_HOST=0.0.0.0
WS_PORT=5050

# Observability skeleton (server/logging_setup.py + server/metrics.py).
# LOG_FORMAT: json (prod) or console (human-readable dev). LOG_LEVEL is
# passed straight to structlog/logging.
LOG_FORMAT=json
LOG_LEVEL=INFO
# Toggle the Prometheus exporter on /metrics. 0 disables the middleware.
METRICS_ENABLED=1

# Sentence chunker for streaming TTS (server/streaming.py). Emit a chunk
# once we've buffered TTS_CHUNK_MIN_CHARS, or after the model has paused
# for TTS_CHUNK_TIMEOUT_MS without a sentence boundary.
TTS_CHUNK_MIN_CHARS=30
TTS_CHUNK_TIMEOUT_MS=400

# Robot mic gate. After the last TTS audio chunk plays, wait this long
# before resubscribing the mic so we don't ingest TTS tail / reverb.
MIC_GATE_GRACE_MS=200

# Robot WS reconnect backoff schedule (ms, comma-separated). The robot
# walks this list on successive reconnect attempts, then stays at the
# last value. Keep ascending; first try should be small enough that a
# transient blip is invisible.
WS_RECONNECT_BACKOFF_MS=300,600,1200,2400

# ──────────────────────────────────────────────────────────────────
# Phase 5 (PRD v2) — CS Navigator integration
# Replaces the bundled Pinecone/Vertex RAG with a thin HTTP proxy onto
# the operator's deployed Cloud Run FastAPI. The chatbot agent calls
# `cs_navigator_search` which POSTs to /chat/guest (no token) or
# /chat/stream (bearer token). See docs/PHASE_5_TASK_MAP.md.
# ──────────────────────────────────────────────────────────────────
# Cloud Run base URL, no trailing slash. Leave blank in dev to disable.
CS_NAVIGATOR_URL=
# Optional bearer token. Empty string -> /chat/guest path. Set this once
# the Cloud Run deployment exposes a real auth token.
CS_NAVIGATOR_TOKEN=
# Request timeout (seconds). 30 is a sane Cloud Run cold-start budget.
CS_NAVIGATOR_TIMEOUT_S=30

# ──────────────────────────────────────────────────────────────────
# Phase 11.8 — ElevenLabs streaming TTS
# Cuts first-audio from ~2 s (OpenAI tts-1) to ~150-300 ms via Flash
# + WebSocket streaming. Falls back to OpenAI TTS when EL key/voice
# isn't set, so it's safe to leave blank in dev.
# ──────────────────────────────────────────────────────────────────
# Master enable. Set to 0 to force OpenAI TTS even when EL is configured.
USE_ELEVENLABS_TTS=1
# Get your key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Model. eleven_flash_v2_5 = fastest. eleven_turbo_v2_5 also fast.
# eleven_multilingual_v2 = higher fidelity but slower.
ELEVENLABS_MODEL=eleven_flash_v2_5
# Output format. mp3_44100_64 is a good default.
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_64
# Three voice IDs from https://elevenlabs.io/app/voice-library or your
# custom voice clones. Users switch profiles mid-session by saying:
#   "voice 1" / "girl voice"     -> ELEVENLABS_VOICE_GIRL
#   "voice 2" / "man voice"      -> ELEVENLABS_VOICE_MAN
#   "voice 3" / "neutral voice"  -> ELEVENLABS_VOICE_NEUTRAL
ELEVENLABS_VOICE_GIRL=
ELEVENLABS_VOICE_MAN=
ELEVENLABS_VOICE_NEUTRAL=
# Server-side default profile when a user hasn't picked one yet.
# One of: girl | man | neutral.
ELEVENLABS_DEFAULT_PROFILE=girl
