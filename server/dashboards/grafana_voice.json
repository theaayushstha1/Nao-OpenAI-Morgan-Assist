          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [],
          "showLegend": true
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (new_state) (rate(nao_camera_state_changes_total[1m])) * 60",
          "legendFormat": "{{new_state}}",
          "exemplar": false
        }
      ]
    },
    {
      "id": 7,
      "title": "Gesture intents (last hour)",
      "description": "Bar chart of gesture tool calls by `intent` label over the last hour. Helps see which gestures (wave, nod, dance, point, etc.) the LLM picks most often. Source: nao_gesture_calls_total counter.",
